# Virtual Environments
.venv/
venv/
env/
ENV/
.vscode/
.idea/

# Byte-compiled files
__pycache__/
*.py[cod]
*$py.class

# Distribution & packaging
*.egg-info/
dist/
build/
*.egg

# Logs & temporary files
logs/
*.log
*.logs

# Data and Artifacts (Large files - managed by DVC)
artifacts/*
!artifacts/*.dvc
data/
raw/
processed/
model/
weights/

# DVC cache (don't track cache, only .dvc files)
.dvc/cache/
.dvc/tmp/

# Jupyter
.ipynb_checkpoints/
*.ipynb

# Environment variables & secrets
.env
.env.local
*.env

# OS generated files
.DS_Store
Thumbs.db

# ML model files (except those tracked by DVC)
*.h5
*.hdf5
*.pkl
*.joblib
*.pth
*.pt
*.onnx

# Large data files
*.csv
*.parquet
*.zip
*.tar.gz

# Pyright / Type checkers
pyrightconfig.json

# Local development
temp/
tmp/